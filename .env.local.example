# Cowork - Environment Variables
# Copy this to .env.local and fill in your values.

# ===== Groq (LLM Provider) =====
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ===== Supabase =====
# Create a project at https://supabase.com, then paste from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ===== Google OAuth =====
# Create at https://console.cloud.google.com — enable Calendar, Tasks, Drive, Docs APIs
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ===== NextAuth =====
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ===== Cost Control =====
MONTHLY_BUDGET_USD=10
DAILY_MESSAGE_LIMIT=30
HOURLY_MESSAGE_LIMIT=10

# ===== GitHub OAuth (native, for Coder/Reviewer agents) =====
# Register an OAuth App at https://github.com/settings/developers
#   Homepage URL: https://your-domain.com
#   Callback URL: https://your-domain.com/api/connectors/github/callback
# Scopes requested at install time: repo, read:org, user:email
GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Composio (Layer 2 integrations — optional) =====
# Sign up at https://app.composio.dev (free tier: 1k tool calls/month).
# Leaving these empty disables Composio; base tools still work.
#
# 1. Get platform key from Dashboard → Developer → API Keys
COMPOSIO_API_KEY=ak_...
# 2. Comma-separated list of toolkits to enable. Must match slugs on
#    Composio dashboard. Start small — users only see what's listed here.
COMPOSIO_TOOLKITS=notion,slack,hubspot
# 3. Per-toolkit Auth Config IDs from Composio dashboard → Apps → <toolkit>
#    → Auth Config. Uppercase the toolkit name for the env var key.
COMPOSIO_AUTH_NOTION=auth_cfg_...
COMPOSIO_AUTH_SLACK=auth_cfg_...
COMPOSIO_AUTH_HUBSPOT=auth_cfg_...
